# ── API Keys ───────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the keys you need.
# Keys can also be entered directly in the Streamlit sidebar.

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Mistral
MISTRAL_API_KEY=...

# ── Ollama ─────────────────────────────────────────────────────────────────
# If running Ollama on a non-standard host/port, set this:
# OLLAMA_API_BASE=http://localhost:11434

# ── ChromaDB ──────────────────────────────────────────────────────────────
# Override the default data directory:
# CHROMA_DB_PATH=./data/chroma
